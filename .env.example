# Safety controls
BOT_ENABLED=false
PAPER_TRADING=true
DRY_RUN=true

# Trading cadence
TRADING_INTERVAL_MINUTES=15
MARKET_TIMEZONE=America/New_York

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Alpaca Paper Trading
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# Risk settings
MAX_POSITION_ALLOCATION_PERCENT=5
MIN_CONFIDENCE=0.70
ALLOWED_SYMBOLS=AAPL,MSFT,NVDA,SPY,QQQ

# Dynamic watchlist scanner
DYNAMIC_WATCHLIST_ENABLED=false
BROAD_MARKET_SCAN_ENABLED=false
BROAD_MARKET_MAX_SYMBOLS=1000
MAX_SCANNER_CANDIDATES_AFTER_FILTERS=1000
BROAD_SCAN_BATCH_SIZE=100
BROAD_SCAN_MAX_REQUESTS_PER_CYCLE=20
MIN_STOCK_PRICE=5
MIN_AVERAGE_VOLUME=500000
EXCLUDE_ETFS=true
WATCHLIST_SIZE=20
SCANNER_UNIVERSE=SPY,QQQ,AAPL,MSFT,NVDA,AMZN,GOOGL,META,TSLA,AMD,NFLX,AVGO,INTC,ORCL,CRM,ADBE,PYPL,UBER,SHOP,PLTR

# Discord notifications
DISCORD_WEBHOOK_URL=
DISCORD_DAILY_SUMMARY_ENABLED=false

# SQLite persistence
DATABASE_PATH=trading_bot.db

# Historical context
DECISION_HISTORY_LIMIT=20
EXECUTION_HISTORY_LIMIT=20
PORTFOLIO_HISTORY_LIMIT=20
INCLUDE_HISTORY_CONTEXT=true
